generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector(schema: "extensions")]
}

model User {
  id               String            @id @default(uuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  role             Role              @default(CANDIDATE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  candidateProfile CandidateProfile?
  ChatMessage      ChatMessage[]
  recruiterProfile RecruiterProfile?
}

model CandidateProfile {
  userId          String          @id
  headline        String?
  bio             String?
  location        String?
  phoneNumber     String?
  linkedinUrl     String?
  githubUsername  String?
  portfolioUrl    String?
  resumeUrl       String?
  experienceLevel ExperienceLevel @default(ENTRY)
  yearsOfExp      Int             @default(0)
  isOpenToWork    Boolean         @default(true)
  hardSkills      Json            @default("{}")
  softSkills      Json            @default("{}")
  // Array of {degree, institution, fieldOfStudy, startYear, endYear, grade}
  education       Json?
  // Array of {title, company, location, startDate, endDate, current, description}
  experience      Json?
  // Array of {name, description, techStack, url, repoUrl}
  projects        Json?
  // Array of {name, issuer, date, url}
  certifications  Json?
  // Array of {language, proficiency}
  languages       Json?
  githubStats     Json?
  lastGithubSync  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  applications    Application[]
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches         Match[]

  @@index([isOpenToWork])
  @@index([experienceLevel])
}

model RecruiterProfile {
  userId      String   @id
  companyName String
  companySize String?
  industry    String?
  website     String?
  logoUrl     String?
  description String?
  location    String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobsPosted  Job[]    @relation("RecruiterJobs")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id               String           @id @default(cuid())
  recruiterId      String
  title            String
  description      String
  location         String?
  isRemote         Boolean          @default(false)
  salaryMin        Int?
  salaryMax        Int?
  currency         String           @default("USD")
  experienceLevel  ExperienceLevel  @default(MID)
  status           JobStatus        @default(DRAFT)
  categoryWeights  Json             @default("{\"experience\": 0.2, \"softSkills\": 0.2, \"technicalSkills\": 0.6}")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  applications     Application[]
  recruiterProfile RecruiterProfile @relation("RecruiterJobs", fields: [recruiterId], references: [userId])
  requirements     JobRequirement[]
  matches          Match[]

  @@index([status])
  @@index([recruiterId])
  @@index([experienceLevel])
}

model JobRequirement {
  id          String  @id @default(cuid())
  jobId       String
  skillName   String
  minLevel    Int
  weight      Float
  isMandatory Boolean @default(false)
  job         Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model Match {
  id              String           @id @default(cuid())
  jobId           String
  candidateId     String
  score           Int
  breakdown       Json
  isShortlisted   Boolean          @default(false)
  isMandatoryPass Boolean          @default(true)
  calculatedAt    DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  candidate       CandidateProfile @relation(fields: [candidateId], references: [userId], onDelete: Cascade)
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId, score])
  @@index([score])
}

model Application {
  id          String            @id @default(cuid())
  jobId       String
  candidateId String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  candidate   CandidateProfile  @relation(fields: [candidateId], references: [userId], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  ChatThread  ChatThread?

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
}

model ChatMessage {
  id         String     @id
  threadId   String
  senderId   String
  content    String
  isRead     Boolean    @default(false)
  createdAt  DateTime   @default(now())
  User       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)
  ChatThread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([senderId])
  @@index([threadId])
}

model ChatThread {
  id            String        @id
  applicationId String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  ChatMessage   ChatMessage[]
  Application   Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}
