// ============================================================
// TALENT MATCHING PLATFORM - PRISMA SCHEMA
// Database: PostgreSQL (Supabase) + pgvector extension
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector(schema: "extensions")]
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  REJECTED
  HIRED
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  EXECUTIVE
}

// ============================================================
// USER MODEL (Supabase Auth — user.id matches auth.users.id)
// ============================================================

model User {
  id               String            @id @default(uuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  role             Role              @default(CANDIDATE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  candidateProfile CandidateProfile?
  recruiterProfile RecruiterProfile?
}

// ============================================================
// CANDIDATE PROFILE
// Primary key is userId (1:1 with User)
// ============================================================

model CandidateProfile {
  userId          String          @id
  headline        String?
  bio             String?
  location        String?
  phoneNumber     String?
  linkedinUrl     String?
  githubUsername  String?
  portfolioUrl    String?
  resumeUrl       String?
  experienceLevel ExperienceLevel @default(ENTRY)
  yearsOfExp      Int             @default(0)
  isOpenToWork    Boolean         @default(true)

  hardSkills      Json            @default("{}")
  softSkills      Json            @default("{}")

  // Resume-standard structured sections (stored as JSON arrays)
  education       Json?           // [{degree, institution, fieldOfStudy, startYear, endYear, grade}]
  experience      Json?           // [{title, company, location, startDate, endDate, current, description}]
  projects        Json?           // [{name, description, techStack, url, repoUrl}]
  certifications  Json?           // [{name, issuer, date, url}]
  languages       Json?           // [{language, proficiency}]

  githubStats     Json?
  lastGithubSync  DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]
  matches         Match[]

  @@index([isOpenToWork])
  @@index([experienceLevel])
}

// ============================================================
// RECRUITER / COMPANY PROFILE
// Primary key is userId (1:1 with User)
// ============================================================

model RecruiterProfile {
  userId      String   @id
  companyName String
  companySize String?
  industry    String?
  website     String?
  logoUrl     String?
  description String?
  location    String?
  isVerified  Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobsPosted  Job[]    @relation("RecruiterJobs")
}

// ============================================================
// JOB POSTING
// ============================================================

model Job {
  id              String           @id @default(cuid())
  recruiterId     String
  title           String
  description     String
  location        String?
  isRemote        Boolean          @default(false)
  salaryMin       Int?
  salaryMax       Int?
  currency        String           @default("USD")
  experienceLevel ExperienceLevel  @default(MID)
  status          JobStatus        @default(DRAFT)
  categoryWeights Json             @default("{\"experience\": 0.2, \"softSkills\": 0.2, \"technicalSkills\": 0.6}")

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  recruiterProfile RecruiterProfile @relation("RecruiterJobs", fields: [recruiterId], references: [userId])
  requirements    JobRequirement[]
  applications    Application[]
  matches         Match[]

  @@index([status])
  @@index([recruiterId])
  @@index([experienceLevel])
}

// ============================================================
// JOB REQUIREMENTS
// ============================================================

model JobRequirement {
  id          String  @id @default(cuid())
  jobId       String
  skillName   String
  minLevel    Int
  weight      Float
  isMandatory Boolean @default(false)

  job         Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ============================================================
// MATCH TABLE
// ============================================================

model Match {
  id              String           @id @default(cuid())
  jobId           String
  candidateId     String
  score           Int
  breakdown       Json
  isShortlisted   Boolean          @default(false)
  isMandatoryPass Boolean          @default(true)
  calculatedAt    DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  candidate       CandidateProfile @relation(fields: [candidateId], references: [userId], onDelete: Cascade)
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId, score])
  @@index([score])
}

// ============================================================
// APPLICATIONS
// ============================================================

model Application {
  id          String            @id @default(cuid())
  jobId       String
  candidateId String
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  candidate   CandidateProfile  @relation(fields: [candidateId], references: [userId], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
}
