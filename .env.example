# ============================================================
# SCALABLE TALENT DISCOVERY & MATCHING PLATFORM - ENV EXAMPLE
# Copy this to .env.local and fill in the values.
# ============================================================

# ---- DATABASE (Supabase PostgreSQL + pgvector) ----
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ---- NEXT-AUTH ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-32-char-secret-here"

# ---- GOOGLE OAUTH (optional for social login) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- GITHUB OAUTH & API (Phase 2: Repository Scraping) ----
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_API_TOKEN=""

# ---- OPENAI (Phase 2: Embedding Generation) ----
OPENAI_API_KEY=""

# ---- SUPABASE (Phase 2: pgvector Semantic Search) ----
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---- UPSTASH REDIS (Phase 3: Caching) ----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
